{
    "image": "ghcr.io/imgproxy/imgproxy-base:v4.0.5",
    "name": "imgproxy OSS",
    "portsAttributes": {
        "8081": {
            "label": "imgproxy",
            "onAutoForward": "notify"
        },
        "8091": {
            "label": "Prometheus metrics",
            "onAutoForward": "silent"
        },
        "8071": {
            "label": "Utilities (pprof, etc.)",
            "onAutoForward": "silent"
        }
    },
    "containerEnv": {
        "PORT": "8081",
        "IMGPROXY_PROMETHEUS_BIND": ":8091",
        "IMGPROXY_LOCAL_FILESYSTEM_ROOT": "/images",
        "IMGPROXY_ENABLE_VIDEO_THUMBNAILS": "true",
        "IMGPROXY_MAX_ANIMATION_FRAMES": "999",
        "IMGPROXY_VIPS_LEAK_CHECK": "true",
        "IMGPROXY_LOG_MEM_STATS": "true",
        "IMGPROXY_DEVELOPMENT_ERRORS_MODE": "true",
        "HISTFILE": "/root/.cache/.bash_history"
    },
    "mounts": [
        {
            "source": "${localWorkspaceFolder}/.devcontainer/images",
            "target": "/images",
            "type": "bind"
        },
        // Unfortunately, devcontainer syntax doesn't support volume-subpath
        // option when specified as an object, have to use string syntax instead.
        "source=imgproxy-cache,target=/root/.cache,type=volume,volume-subpath=cache",
        "source=imgproxy-cache,target=/root/go/pkg/mod,type=volume,volume-subpath=go-mod"
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "golang.go",
                "ms-vscode.cpptools"
            ]
        }
    },
    "postCreateCommand": "lefthook install",
    "initializeCommand": {
        // volume-subpaths must be created before volume is mounted, hence we need to call mkdir.
        // there's no way to reference ${image} of the devcontainer here, so, we use the smallest
        // image possible (busybox) to create the volume subpaths.
        "createCacheVolume": "docker run --rm -v imgproxy-cache:/data busybox sh -c 'mkdir -p /data/cache /data/go-mod && touch /data/cache/.bash_history'",
        "linkImagesDir": "if [ ! -e ${localWorkspaceFolder}/.devcontainer/images ]; then ln -s ${localWorkspaceFolder}/testdata/test-images ${localWorkspaceFolder}/.devcontainer/images; fi"
    }
}
